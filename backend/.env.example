# BharatAero Backend Configuration
# Copy this to .env and fill in your values

# Server
PORT=5000
NODE_ENV=production

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bharataero
DB_USER=bharataero_user
DB_PASSWORD=your_secure_password_here

# Redis (OTP Storage)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT Authentication - REQUIRED - Generate secure key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_64_character_secure_random_key_here_generate_new_one

# Email Service (Resend)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@bharataero.com

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Security
CSRF_SECRET=generate_random_secret_here
